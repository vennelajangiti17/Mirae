{
  "manifest_version": 3,
  "name": "Mirae Job Scraper",
  "version": "1.0",
  "description": "Extract job details and save them instantly to your Mirae dashboard.",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Mirae"
  }
}
