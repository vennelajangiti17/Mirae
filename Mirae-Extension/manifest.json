{
  "manifest_version": 3,
  "name": "Mirae AI Job Tracker",
  "version": "1.1",
  "description": "Smart scraper for the Mirae application tracking dashboard.",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mirae"
  }
}
